# ═══════════════════════════════════════
# GSS ORION V3 — Environment Variables
# Copy to .env and fill in your values.
# The system works in SIM mode without any keys.
# ═══════════════════════════════════════

# LLM Provider (optional — uncomment and fill ONE)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Model override (default: ollama/llama3.2)
# GSS_LLM_MODEL=gemini/gemini-2.0-flash

# Ollama (auto-detected if running on localhost:11434)
# OLLAMA_HOST=http://localhost:11434
